# Copie para .env e preencha — segredos reais nunca entram no git

# Banco (Supabase): pooler na 6543 pra runtime, direct na 5432 pra migrations
DATABASE_URL="postgresql://user:pass@host:5432/postgres"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# Auth JWT próprio — gerar com:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRES_IN="15m"

# Só usada por `npx prisma db seed` — nunca commitada, nunca hardcoded no seed.ts
SEED_ADMIN_PASSWORD=""

# Rastreador Assemilsat (auth: POST form-urlencoded usuario/senha)
ASSEMILSAT_API_URL="https://novo.assemilsat.com.br"
ASSEMILSAT_API_LOGIN=""
ASSEMILSAT_API_SENHA=""

# mock | live — em live o cron consome a fila de posições a cada 5 min
TRACKER_MODE="mock"

# NFSe Emissor Nacional (governo — nota fiscal de serviço)
NFSE_URL="https://www.nfse.gov.br/EmissorNacional/Login"
NFSE_CNPJ=""
NFSE_SENHA=""

# Portais de posto de combustível — login web, API não confirmada ainda
POSTO_ARGO_URL="https://tradicao.argosistemas.com/#/splashScreen"
POSTO_ARGO_LOGIN=""
POSTO_ARGO_SENHA=""

POSTO_FROTAFLEX_URL="https://russi.frotaflex.com.br/faturas"
POSTO_FROTAFLEX_LOGIN=""
POSTO_FROTAFLEX_SENHA=""

POSTO_QUALITY_URL="https://www.qualityautomacao.com.br/webfrota/#/login"
POSTO_QUALITY_LOGIN=""
POSTO_QUALITY_SENHA=""

# mock | live — em live precisa da chave do provedor escolhido configurada.
# LLM_PROVIDER=gemini é o padrão (pedido do cliente); troca pra "anthropic"
# sem mudar código. Confirmar o ID exato do modelo Gemini "Flash" vigente em
# ai.google.dev/gemini-api/docs/models antes de virar live.
OCR_MODE="mock"
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
ANTHROPIC_API_KEY=""
