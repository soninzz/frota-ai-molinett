# Copie para .env e preencha — segredos reais nunca entram no git

# Banco (Supabase): pooler na 6543 pra runtime, direct na 5432 pra migrations
DATABASE_URL="postgresql://user:pass@host:5432/postgres"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# Auth JWT próprio — gerar com:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRES_IN="15m"

# Rastreador Assemilsat (auth: POST form-urlencoded usuario/senha)
ASSEMILSAT_API_URL="https://novo.assemilsat.com.br"
ASSEMILSAT_API_LOGIN=""
ASSEMILSAT_API_SENHA=""

# mock | live — em live o cron consome a fila de posições a cada 5 min
TRACKER_MODE="mock"
